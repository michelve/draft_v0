{
    "name": "draft-v0",
    "private": true,
    "version": "0.2.2",
    "type": "module",
    "scripts": {
        "dev": "concurrently -k \"vite\" \"tsx watch --env-file=.env src/server/index.ts\"",
        "dev:ci": "concurrently -k \"vite\" \"tsx watch src/server/index.ts\"",
        "build": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json && vite build",
        "preview": "vite preview",
        "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "biome:check": "biome check .",
        "biome:fix": "biome check . --write",
        "test": "vitest",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "db:push": "prisma db push",
        "db:studio": "prisma studio",
        "db:generate": "prisma generate",
        "knip": "knip",
        "changeset": "changeset",
        "version-packages": "changeset version",
        "release": "changeset publish",
        "prepare": "husky"
    },
    "dependencies": {
        "@hookform/resolvers": "^3.9.0",
        "@prisma/client": "^6.4.0",
        "@tanstack/react-query": "^5.95.0",
        "@tanstack/react-router": "^1.168.2",
        "class-variance-authority": "^0.7.1",
        "cors": "^2.8.5",
        "express": "^4.21.0",
        "express-rate-limit": "^8.3.0",
        "helmet": "^8.1.0",
        "lucide-react": "^0.577.0",
        "radix-ui": "^1.4.3",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-hook-form": "^7.54.0",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.3.6",
        "zustand": "^5.0.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.6",
        "@changesets/cli": "^2.30.0",
        "@commitlint/cli": "^20.4.3",
        "@commitlint/config-conventional": "^20.4.3",
        "@eslint/js": "^10.0.1",
        "@figma/code-connect": "^1.4.1",
        "@playwright/test": "^1.58.2",
        "@tailwindcss/vite": "^4.0.0",
        "@tanstack/router-plugin": "^1.167.3",
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/node": "^22.10.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^4.3.0",
        "clsx": "^2.1.0",
        "concurrently": "^9.1.0",
        "eslint": "^10.0.3",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "knip": "^5.86.0",
        "lint-staged": "^16.3.2",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "prisma": "^6.4.0",
        "tailwind-merge": "^2.6.0",
        "tailwindcss": "^4.0.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "typescript-eslint": "^8.56.1",
        "vite": "^6.1.0",
        "vitest": "^3.0.0"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@prisma/client",
            "@prisma/engines",
            "esbuild",
            "prisma"
        ]
    },
    "lint-staged": {
        "*.{ts,tsx}": "biome check --write",
        "*.{css,scss,md,json,yaml,yml}": "prettier --write --ignore-unknown"
    }
}
