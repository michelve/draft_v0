{
    "shadow": {
        "default": {
            "$value": "0 0.5rem 1rem rgba(0, 0, 0, 0.15)",
            "$type": "shadow",
            "$description": "Complete box shadow value for Bootstrap SCSS export",
            "$extensions": {
                "docs": {
                    "reference": "https://getbootstrap.com/docs/5.3/utilities/shadows/"
                },
                "platform": {
                    "scssVariableName": "$box-shadow"
                }
            }
        },
        "sm": {
            "$value": "0 0.125rem 0.25rem rgba(0, 0, 0, 0.075)",
            "$type": "shadow",
            "$description": "Complete box shadow value for Bootstrap SCSS export",
            "$extensions": {
                "docs": {
                    "reference": "https://getbootstrap.com/docs/5.3/utilities/shadows/"
                },
                "platform": {
                    "scssVariableName": "$box-shadow-sm"
                }
            }
        },
        "lg": {
            "$value": "0 1rem 3rem rgba(0, 0, 0, 0.175)",
            "$type": "shadow",
            "$description": "Complete box shadow value for Bootstrap SCSS export",
            "$extensions": {
                "docs": {
                    "reference": "https://getbootstrap.com/docs/5.3/utilities/shadows/"
                },
                "platform": {
                    "scssVariableName": "$box-shadow-lg"
                }
            }
        },
        "inset": {
            "$value": "inset 0 1px 2px rgba(0, 0, 0, 0.075)",
            "$type": "shadow",
            "$description": "Complete box shadow value for Bootstrap SCSS export",
            "$extensions": {
                "docs": {
                    "reference": "https://getbootstrap.com/docs/5.3/utilities/shadows/"
                },
                "platform": {
                    "scssVariableName": "$box-shadow-inset"
                }
            }
        }
    }
}
