{
    "layout": {
        "container": {
            "max-width": {
                "sm": {
                    "$value": "540px",
                    "$type": "dimension",
                    "$description": "Maximum container width at small breakpoint (540px). Container width for landscape phones and small tablets.",
                    "$extensions": {
                        "docs": {
                            "reference": "https://getbootstrap.com/docs/5.3/layout/containers/#how-they-work"
                        },
                        "platform": {
                            "scssVariableName": "$container-max-widths.sm",
                            "cssClass": ".container",
                            "lightMode": "true",
                            "darkMode": "true"
                        }
                    }
                },
                "md": {
                    "$value": "720px",
                    "$type": "dimension",
                    "$description": "Maximum container width at medium breakpoint (720px). Container width optimized for tablets.",
                    "$extensions": {
                        "docs": {
                            "reference": "https://getbootstrap.com/docs/5.3/layout/containers/#how-they-work"
                        },
                        "platform": {
                            "scssVariableName": "$container-max-widths.md",
                            "cssClass": ".container",
                            "lightMode": "true",
                            "darkMode": "true"
                        }
                    }
                },
                "lg": {
                    "$value": "960px",
                    "$type": "dimension",
                    "$description": "Maximum container width at large breakpoint (960px). Standard desktop container width.",
                    "$extensions": {
                        "docs": {
                            "reference": "https://getbootstrap.com/docs/5.3/layout/containers/#how-they-work"
                        },
                        "platform": {
                            "scssVariableName": "$container-max-widths.lg",
                            "cssClass": ".container",
                            "lightMode": "true",
                            "darkMode": "true"
                        }
                    }
                },
                "xl": {
                    "$value": "1140px",
                    "$type": "dimension",
                    "$description": "Maximum container width at extra large breakpoint (1140px). Wide desktop container width.",
                    "$extensions": {
                        "docs": {
                            "reference": "https://getbootstrap.com/docs/5.3/layout/containers/#how-they-work"
                        },
                        "platform": {
                            "scssVariableName": "$container-max-widths.xl",
                            "cssClass": ".container",
                            "lightMode": "true",
                            "darkMode": "true"
                        }
                    }
                },
                "xxl": {
                    "$value": "1320px",
                    "$type": "dimension",
                    "$description": "Maximum container width at extra extra large breakpoint (1320px). Widest container for ultra-wide displays.",
                    "$extensions": {
                        "docs": {
                            "reference": "https://getbootstrap.com/docs/5.3/layout/containers/#how-they-work"
                        },
                        "platform": {
                            "scssVariableName": "$container-max-widths.xxl",
                            "cssClass": ".container",
                            "lightMode": "true",
                            "darkMode": "true"
                        }
                    }
                }
            },
            "padding-x": {
                "$value": "12px",
                "$type": "dimension",
                "$description": "Horizontal padding for containers (12px left and right). Applied by the make-container mixin for content spacing.",
                "$extensions": {
                    "docs": {
                        "reference": "https://getbootstrap.com/docs/5.3/layout/containers/#sass-mixins"
                    },
                    "platform": {
                        "scssVariableName": "$container-padding-x",
                        "cssClass": ".container",
                        "lightMode": "true",
                        "darkMode": "true"
                    }
                }
            }
        }
    }
}
