{
    "layout": {
        "breakpoints": {
            "xs": {
                "$value": "0px",
                "$type": "dimension",
                "$description": "Extra small breakpoint for portrait phones (min-width: 0). Bootstrap's default mobile-first starting point.",
                "$extensions": {
                    "docs": {
                        "reference": "https://getbootstrap.com/docs/5.3/layout/breakpoints/#available-breakpoints"
                    },
                    "platform": {
                        "scssVariableName": "$grid-breakpoints.xs",
                        "mediaQuery": "No media query (default)",
                        "lightMode": "true",
                        "darkMode": "true"
                    }
                }
            },
            "sm": {
                "$value": "576px",
                "$type": "dimension",
                "$description": "Small breakpoint for landscape phones (≥576px). First responsive breakpoint in Bootstrap's mobile-first approach.",
                "$extensions": {
                    "docs": {
                        "reference": "https://getbootstrap.com/docs/5.3/layout/breakpoints/#available-breakpoints"
                    },
                    "platform": {
                        "scssVariableName": "$grid-breakpoints.sm",
                        "mediaQuery": "@media (min-width: 576px)",
                        "lightMode": "true",
                        "darkMode": "true"
                    }
                }
            },
            "md": {
                "$value": "768px",
                "$type": "dimension",
                "$description": "Medium breakpoint for tablets (≥768px). Common tablet viewport size for responsive layouts.",
                "$extensions": {
                    "docs": {
                        "reference": "https://getbootstrap.com/docs/5.3/layout/breakpoints/#available-breakpoints"
                    },
                    "platform": {
                        "scssVariableName": "$grid-breakpoints.md",
                        "mediaQuery": "@media (min-width: 768px)",
                        "lightMode": "true",
                        "darkMode": "true"
                    }
                }
            },
            "lg": {
                "$value": "992px",
                "$type": "dimension",
                "$description": "Large breakpoint for desktops (≥992px). Standard desktop viewport size for responsive web design.",
                "$extensions": {
                    "docs": {
                        "reference": "https://getbootstrap.com/docs/5.3/layout/breakpoints/#available-breakpoints"
                    },
                    "platform": {
                        "scssVariableName": "$grid-breakpoints.lg",
                        "mediaQuery": "@media (min-width: 992px)",
                        "lightMode": "true",
                        "darkMode": "true"
                    }
                }
            },
            "xl": {
                "$value": "1200px",
                "$type": "dimension",
                "$description": "Extra large breakpoint for large desktops (≥1200px). Wide desktop viewport for expansive layouts.",
                "$extensions": {
                    "docs": {
                        "reference": "https://getbootstrap.com/docs/5.3/layout/breakpoints/#available-breakpoints"
                    },
                    "platform": {
                        "scssVariableName": "$grid-breakpoints.xl",
                        "mediaQuery": "@media (min-width: 1200px)",
                        "lightMode": "true",
                        "darkMode": "true"
                    }
                }
            },
            "xxl": {
                "$value": "1400px",
                "$type": "dimension",
                "$description": "Extra extra large breakpoint for larger desktops (≥1400px). Widest default viewport for ultra-wide displays.",
                "$extensions": {
                    "docs": {
                        "reference": "https://getbootstrap.com/docs/5.3/layout/breakpoints/#available-breakpoints"
                    },
                    "platform": {
                        "scssVariableName": "$grid-breakpoints.xxl",
                        "mediaQuery": "@media (min-width: 1400px)",
                        "lightMode": "true",
                        "darkMode": "true"
                    }
                }
            }
        }
    }
}
