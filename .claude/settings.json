{
    "permissions": {
        "allow": [],
        "deny": []
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "python3 .claude/hooks/commitlint-enforcer.py"
                    }
                ]
            },
            {
                "matcher": "Write|Edit|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "python3 .claude/hooks/anti-pattern-guard.py"
                    }
                ]
            }
        ],
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "python3 .claude/hooks/adr-gate.py"
                    }
                ]
            },
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "python3 .claude/hooks/task-context-injector.py"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Write|Edit|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "python3 .claude/hooks/quality-gate-reminder.py"
                    }
                ]
            }
        ]
    },
    "mcpServers": {
        "context7": {
            "command": "npx",
            "args": ["-y", "@upstash/context7-mcp@latest"]
        },
        "playwright": {
            "command": "npx",
            "args": ["-y", "@playwright/mcp@latest"]
        },
        "figma": {
            "command": "npx",
            "args": ["-y", "figma-developer-mcp", "--figma-api-key=$FIGMA_API_KEY", "--stdio"]
        },
        "figma-console": {
            "command": "npx",
            "args": ["-y", "figma-console-mcp", "--figma-api-key=$FIGMA_API_KEY"]
        },
        "sequential-thinking": {
            "command": "npx",
            "args": ["-y", "@anthropic/sequential-thinking-mcp"]
        },
        "miro-mcp": {
            "url": "https://mcp.miro.com/",
            "disabled": false,
            "autoApprove": []
        }
    }
}
